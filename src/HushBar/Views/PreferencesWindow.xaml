<Window x:Class="HushBar.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HushBar Preferences"
        Width="520" Height="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#F5F5F5">
    <Window.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ColorSwatch" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="4"
                                BorderThickness="1.5" BorderBrush="#CCC"
                                Background="{TemplateBinding Background}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PopupColor" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="3"
                                BorderThickness="1.5" BorderBrush="Transparent"
                                Background="{TemplateBinding Background}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Preset list -->
        <DockPanel Grid.Column="0" Margin="0,0,12,0">
            <TextBlock DockPanel.Dock="Top" Text="HushBar" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,2"/>
            <TextBlock DockPanel.Dock="Top" Foreground="#999" FontSize="11" Margin="0,0,0,10"
                       Text="Global mic mute from the tray."/>

            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                <Button x:Name="AddBtn" Content="+" Width="28" Height="24" Click="OnAddPreset"
                        FontSize="14" FontWeight="Bold" Margin="0,0,4,0"/>
                <Button x:Name="RemoveBtn" Content="&#x2212;" Width="28" Height="24" Click="OnRemovePreset"
                        FontSize="14" FontWeight="Bold"/>
            </StackPanel>

            <TextBlock DockPanel.Dock="Top" Style="{StaticResource SectionLabel}" Text="PRESETS"/>
            <ListBox x:Name="PresetList" SelectionChanged="OnPresetSelected"
                     DisplayMemberPath="Name" BorderThickness="1" BorderBrush="#DDD"/>
        </DockPanel>

        <!-- Right: Editor + settings -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Preset editor -->
                <Border x:Name="EditorPanel" Background="White" CornerRadius="6"
                        BorderThickness="1" BorderBrush="#DDD" Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionLabel}" Text="PRESET EDITOR"/>

                        <!-- Name -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Name"/>
                            <TextBox x:Name="NameBox" Grid.Column="1" Style="{StaticResource FieldBox}"
                                     TextChanged="OnNameChanged"/>
                        </Grid>

                        <!-- On label -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="On label"/>
                            <TextBox x:Name="OnTextBox" Grid.Column="1" Style="{StaticResource FieldBox}"
                                     TextChanged="OnOnTextChanged"/>
                        </Grid>

                        <!-- Off label -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Off label"/>
                            <TextBox x:Name="OffTextBox" Grid.Column="1" Style="{StaticResource FieldBox}"
                                     TextChanged="OnOffTextChanged"/>
                        </Grid>

                        <!-- On color -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="On color"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="OnColorBtn" Style="{StaticResource ColorSwatch}"
                                        Click="OnOnColorClick"/>
                                <Popup x:Name="OnColorPopup" StaysOpen="False"
                                       Placement="Bottom" PlacementTarget="{Binding ElementName=OnColorBtn}"
                                       AllowsTransparency="True">
                                    <Border Background="White" CornerRadius="6" Padding="6"
                                            BorderThickness="1" BorderBrush="#CCC">
                                        <WrapPanel x:Name="OnColorPalette" Width="168"/>
                                    </Border>
                                </Popup>
                            </StackPanel>
                        </Grid>

                        <!-- Off color -->
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Off color"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="OffColorBtn" Style="{StaticResource ColorSwatch}"
                                        Click="OnOffColorClick"/>
                                <Popup x:Name="OffColorPopup" StaysOpen="False"
                                       Placement="Bottom" PlacementTarget="{Binding ElementName=OffColorBtn}"
                                       AllowsTransparency="True">
                                    <Border Background="White" CornerRadius="6" Padding="6"
                                            BorderThickness="1" BorderBrush="#CCC">
                                        <WrapPanel x:Name="OffColorPalette" Width="168"/>
                                    </Border>
                                </Popup>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Preview -->
                <Border Background="White" CornerRadius="6"
                        BorderThickness="1" BorderBrush="#DDD" Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionLabel}" Text="PREVIEW"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,4">
                            <Border x:Name="PreviewOnBorder" CornerRadius="4" Padding="10,4" Margin="0,0,8,0">
                                <TextBlock x:Name="PreviewOnText" FontSize="12" FontWeight="SemiBold"
                                           Foreground="White"/>
                            </Border>
                            <Border x:Name="PreviewOffBorder" CornerRadius="4" Padding="10,4">
                                <TextBlock x:Name="PreviewOffText" FontSize="12" FontWeight="SemiBold"
                                           Foreground="White"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- General settings -->
                <Border Background="White" CornerRadius="6"
                        BorderThickness="1" BorderBrush="#DDD" Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionLabel}" Text="GENERAL"/>
                        <CheckBox x:Name="SoundCheck" Content="Play sound on toggle" Margin="0,4"/>
                        <CheckBox x:Name="StartupCheck" Content="Launch at login" Margin="0,4"/>
                    </StackPanel>
                </Border>

                <!-- Mic status -->
                <Border Background="White" CornerRadius="6"
                        BorderThickness="1" BorderBrush="#DDD" Padding="14">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionLabel}" Text="MICROPHONE"/>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="MicDot" Width="10" Height="10" Margin="0,0,8,0"/>
                            <TextBlock x:Name="MicStatusText" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
